# シークレット。`.env` にコピーして使う（.env は git 管理外）。
# Phase 0/1 で各ツールを選定・契約したら設定する。

# YouTube Data / Analytics API（OAuth クライアントの JSON へのパス）
# YOUTUBE_CLIENT_SECRET_FILE=secrets/client_secret.json

# 音楽：Suno Pro（$10/月）＋人間アシスト。公式APIなしのためAPIキーは不要。
# 人間が Suno Web で生成・DL し data/assets/music/<video_id>/ に投入する運用。
# （将来 Suno Premier の公式API or ElevenLabs に移行する場合のみキーを設定）
# MUSIC_API_KEY=

# 画像生成（商用可ツール）
# IMAGE_API_KEY=

# 企画/メタデータ生成 LLM
# LLM_API_KEY=
